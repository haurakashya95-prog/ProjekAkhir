<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.kidsdaycareactivitycenter.DashboardCaregiver.DashboardCaregiverController"
            prefWidth="1250"
            prefHeight="720"
            style="-fx-background-color:#F5F7FB;">

    <children>

        <VBox layoutX="15" layoutY="15"
              prefWidth="1220" prefHeight="690"
              spacing="15"
              style="-fx-background-color:white;-fx-background-radius:18;-fx-border-color:#E5E7EB;-fx-border-radius:18;">

            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="15">

                <Label text="🧸" style="-fx-font-size:32;"/>

                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="KIDDIELAND"
                               style="-fx-font-size:24;-fx-font-weight:bold;"/>
                        <Label text="CAREGIVER DASHBOARD"
                               style="-fx-font-size:12;-fx-text-fill:#6B7280;"/>
                    </children>
                </VBox>

                <VBox alignment="CENTER_RIGHT">
                    <children>
                        <Label text="● STATUS ONLINE"
                               style="-fx-text-fill:#16A34A;-fx-font-size:10;"/>
                        <Label fx:id="lblCaregiver"
                               text="Caregiver"
                               style="-fx-font-weight:bold;"/>
                        <HBox spacing="5">
                            <children>
                                <Label text="12 Jul"/>
                                <Label text="|"/>
                                <Label text="10:21"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Button fx:id="btnLogout"
                        text="Keluar"
                        onAction="#logout"
                        prefWidth="90"
                        style="-fx-background-color:#EF4444;-fx-text-fill:white;-fx-background-radius:8;"/>

            </HBox>

            <Separator/>

            <!-- STATISTIC -->
            <GridPane hgap="8">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <children>

                    <VBox GridPane.columnIndex="0" spacing="6"
                          style="-fx-border-color:#E5E7EB;-fx-background-radius:10;-fx-padding:10;">
                        <children>
                            <Label text="Total Anak Hari Ini"/>
                            <Label fx:id="lblTotalAnak"
                                   text="0"
                                   style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#2563EB;"/>
                        </children>
                    </VBox>

                    <VBox GridPane.columnIndex="1" spacing="6"
                          style="-fx-border-color:#E5E7EB;-fx-padding:10;">
                        <children>
                            <Label text="Check In"/>
                            <Label fx:id="lblCheckIn"
                                   text="0"
                                   style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#16A34A;"/>
                        </children>
                    </VBox>

                    <VBox GridPane.columnIndex="2" spacing="6"
                          style="-fx-border-color:#E5E7EB;-fx-padding:10;">
                        <children>
                            <Label text="Belum Check In"/>
                            <Label fx:id="lblBelumCheckIn"
                                   text="0"
                                   style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#F59E0B;"/>
                        </children>
                    </VBox>

                    <VBox GridPane.columnIndex="3" spacing="6"
                          style="-fx-border-color:#E5E7EB;-fx-padding:10;">
                        <children>
                            <Label text="Check Out"/>
                            <Label fx:id="lblCheckOut"
                                   text="0"
                                   style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#EF4444;"/>
                        </children>
                    </VBox>

                </children>
            </GridPane>

            <HBox spacing="15" VBox.vgrow="ALWAYS">

                <VBox prefWidth="300" spacing="12"
                      style="-fx-border-color:#E5E7EB;">
                    <padding><Insets top="10" left="10" right="10"/></padding>
                    <children>
                        <Label text="• OPERASIONAL"
                               style="-fx-font-size:16;-fx-font-weight:bold;"/>
                        <Button fx:id="btnCheckIn" text="➡ Check In Anak" onAction="#checkIn"
                                prefHeight="45"
                                style="-fx-background-color:#DCEBFF;-fx-alignment:CENTER_LEFT;"/>
                        <Button fx:id="btnDailyActivity" text="🕒 Daily Activity" onAction="#dailyActivity"
                                prefHeight="45"
                                style="-fx-background-color:#DCFCE7;-fx-alignment:CENTER_LEFT;"/>
                        <Button fx:id="btnCheckOut" text="🚪 Check Out Anak" onAction="#checkOut"
                                prefHeight="45"
                                style="-fx-background-color:#FFE8CC;-fx-alignment:CENTER_LEFT;"/>
                    </children>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <children>

                        <HBox spacing="10">
                            <children>
                                <Label text="Cari Anak"/>
                                <TextField fx:id="txtCari" HBox.hgrow="ALWAYS"
                                           promptText="Masukkan nama anak..."/>
                                <Button fx:id="btnCari"
                                        text="Cari"
                                        onAction="#cari"/>
                            </children>
                        </HBox>

                        <Label text="Data Anak Hari Ini"
                               style="-fx-font-weight:bold;"/>

                        <TableView fx:id="tblAnak" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colID" text="ID Anak" prefWidth="120"/>
                                <TableColumn fx:id="colNama" text="Nama Anak" prefWidth="300"/>
                                <TableColumn fx:id="colCheckIn" text="Check In" prefWidth="120"/>
                                <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                                <TableColumn fx:id="colAksi" text="Aksi" prefWidth="120"/>
                            </columns>
                        </TableView>

                    </children>
                </VBox>

            </HBox>

            <Separator/>

            <HBox>
                <children>
                    <Label fx:id="lblStatus"
                           text="Caregiver - Status Online"
                           HBox.hgrow="ALWAYS"/>
                    <Label text="KIDDIELAND CAREGIVER v1.0"/>
                </children>
            </HBox>

        </VBox>

    </children>

</AnchorPane>
