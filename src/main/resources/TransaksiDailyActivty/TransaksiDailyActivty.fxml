<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1400"
            prefHeight="850"
            style="-fx-background-color:#F5F7FA;"
            fx:controller="com.example.kidsdaycareactivitycenter.TransaksiDailyActivty.TransaksiDailyActivtyController">

    <!-- ================= HEADER ================= -->

    <top>

        <VBox spacing="15"
              style="-fx-background-color:white;
                     -fx-border-color:#E5E7EB;
                     -fx-border-width:0 0 1 0;">

            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <HBox alignment="CENTER_LEFT">

                <VBox spacing="3">

                    <Label text="KIDDIELAND"
                           style="-fx-font-size:28;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1F2937;"/>

                    <Label text="DAILY ACTIVITY FORM"
                           style="-fx-font-size:15;
                                  -fx-text-fill:#64748B;"/>

                </VBox>

                <Pane HBox.hgrow="ALWAYS"/>

                <VBox alignment="CENTER_RIGHT"
                      spacing="5">

                    <Label fx:id="lblStatus"
                           text="● STATUS ONLINE"
                           style="-fx-text-fill:#22C55E;
                                  -fx-font-size:13;
                                  -fx-font-weight:bold;"/>

                    <Label fx:id="lblNamaCaregiver"
                           text="Caregiver"
                           style="-fx-font-size:20;
                                  -fx-font-weight:bold;"/>

                    <Label fx:id="lblTanggalJam"
                           text="12 Jul | 10:21"
                           style="-fx-font-size:14;"/>

                </VBox>

                <Button fx:id="btnLogout"
                        text="Logout"
                        prefWidth="120"
                        prefHeight="40"
                        style="-fx-background-color:#EF4444;
                               -fx-text-fill:white;
                               -fx-background-radius:8;
                               -fx-font-weight:bold;"/>

            </HBox>

        </VBox>

    </top>

    <!-- ================= BODY ================= -->

    <center>

        <HBox spacing="20">

            <padding>
                <Insets top="20" left="20" right="20" bottom="20"/>
            </padding>

            <!-- ================= SIDEBAR ================= -->

            <VBox spacing="18"
                  prefWidth="320">

                <!-- Back Button -->

                <HBox alignment="CENTER_LEFT"
                      spacing="10">

                    <Button fx:id="btnBack"
                            text="← Back"
                            prefWidth="80"
                            prefHeight="40"
                            style="-fx-background-color:#3B82F6;
                                   -fx-text-fill:white;
                                   -fx-background-radius:8;
                                   -fx-font-weight:bold;"/>

                    <Label text="Dashboard Caregiver /"/>

                    <Label text="Daily Activity"
                           style="-fx-font-weight:bold;"/>

                </HBox>

                <!-- Menu Operasional -->

                <VBox spacing="15"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-padding:20;
                             -fx-border-color:#E5E7EB;">

                    <Label text="• OPERASIONAL"
                           style="-fx-font-size:18;
                                  -fx-font-weight:bold;"/>

                    <Button fx:id="btnCheckIn"
                            text="➜ Check In Anak"
                            prefHeight="55"
                            maxWidth="Infinity"
                            style="-fx-background-color:#DBEAFE;
                                   -fx-text-fill:#2563EB;
                                   -fx-font-size:17;
                                   -fx-font-weight:bold;
                                   -fx-background-radius:10;"/>

                    <Button fx:id="btnDailyActivity"
                            text="⏱ Daily Activity"
                            prefHeight="55"
                            maxWidth="Infinity"
                            style="-fx-background-color:#DCFCE7;
                                   -fx-text-fill:#15803D;
                                   -fx-font-size:17;
                                   -fx-font-weight:bold;
                                   -fx-background-radius:10;"/>

                    <Button fx:id="btnCheckOut"
                            text="⏻ Check Out Anak"
                            prefHeight="55"
                            maxWidth="Infinity"
                            style="-fx-background-color:#FDE7C7;
                                   -fx-text-fill:#C2410C;
                                   -fx-font-size:17;
                                   -fx-font-weight:bold;
                                   -fx-background-radius:10;"/>

                </VBox>

                <!-- Data Anak Terpilih -->

                <VBox spacing="12"
                      style="-fx-background-color:white;
                             -fx-padding:20;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;">

                    <Label text="ANAK TERPILIH"
                           style="-fx-font-size:16;
                                  -fx-font-weight:bold;"/>

                    <GridPane hgap="10"
                              vgap="12">

                        <Label text="ID Anak"
                               style="-fx-font-weight:bold;"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="0"/>

                        <Label fx:id="lblIDAnak"
                               text="-"
                               style="-fx-font-weight:bold;
                                      -fx-text-fill:#3B82F6;"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="1"/>

                        <Label text="Nama Anak"
                               style="-fx-font-weight:bold;"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="0"/>

                        <Label fx:id="lblNamaAnak"
                               text="-"
                               style="-fx-font-weight:bold;
                                      -fx-text-fill:#3B82F6;"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"/>

                        <Label text="Status"
                               style="-fx-font-weight:bold;"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="0"/>

                        <Label fx:id="lblStatusAnak"
                               text="-"
                               style="-fx-font-weight:bold;
                                      -fx-text-fill:#22C55E;"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="1"/>

                    </GridPane>

                </VBox>

            </VBox>

            <!-- ================= MAIN CONTENT ================= -->

            <VBox spacing="20"
                  HBox.hgrow="ALWAYS">

                <!-- ================= DATA TRANSAKSI ================= -->

                <VBox spacing="18"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;
                             -fx-padding:20;">

                    <Label text="📋 DATA TRANSAKSI"
                           style="-fx-font-size:20;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1F2937;"/>

                    <GridPane hgap="18" vgap="15">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>

                        <!-- Transaksi Daycare -->

                        <VBox spacing="8"
                              GridPane.columnIndex="0">

                            <Label text="Transaksi Daycare"
                                   style="-fx-font-weight:bold;"/>

                            <ComboBox fx:id="cmbDaycare"
                                      prefHeight="42"
                                      promptText="Pilih transaksi daycare..."
                                      maxWidth="Infinity"
                                      style="-fx-font-size:14;"/>

                        </VBox>

                        <!-- Activity Schedule -->

                        <VBox spacing="8"
                              GridPane.columnIndex="1">

                            <Label text="Jadwal Kegiatan"
                                   style="-fx-font-weight:bold;"/>

                            <ComboBox fx:id="cmbActivity"
                                      prefHeight="42"
                                      promptText="Pilih schedule..."
                                      maxWidth="Infinity"
                                      style="-fx-font-size:14;"/>

                        </VBox>

                        <!-- Caregiver -->

                        <VBox spacing="8"
                              GridPane.columnIndex="2">

                            <Label text="Karyawan / Caregiver"
                                   style="-fx-font-weight:bold;"/>

                            <TextField fx:id="txtCaregiver"
                                       prefHeight="42"
                                       editable="false"
                                       style="-fx-font-size:14;
                                              -fx-control-inner-background:#F3F4F6;"/>

                        </VBox>

                        <!-- Tanggal Kegiatan -->

                        <VBox spacing="8"
                              GridPane.columnIndex="3">

                            <Label text="Tanggal Kegiatan"
                                   style="-fx-font-weight:bold;"/>

                            <DatePicker fx:id="dpTanggal"
                                        prefHeight="42"
                                        maxWidth="Infinity"
                                        style="-fx-font-size:14;"/>

                        </VBox>

                    </GridPane>

                </VBox>

                <!-- ================= TIMELINE KEGIATAN ================= -->

                <VBox spacing="20"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;
                             -fx-padding:20;">

                    <Label text="⏰ TIMELINE KEGIATAN"
                           style="-fx-font-size:20;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1F2937;"/>

                    <ScrollPane fitToWidth="true"
                                style="-fx-border-color:transparent;
                                       -fx-background-color:transparent;">

                        <GridPane hgap="15"
                                  vgap="20">

                            <columnConstraints>
                                <ColumnConstraints percentWidth="14.2"/>
                                <ColumnConstraints percentWidth="14.2"/>
                                <ColumnConstraints percentWidth="14.2"/>
                                <ColumnConstraints percentWidth="14.2"/>
                                <ColumnConstraints percentWidth="14.2"/>
                                <ColumnConstraints percentWidth="14.2"/>
                                <ColumnConstraints percentWidth="14.2"/>
                            </columnConstraints>

                            <!-- CHECK IN -->

                            <VBox alignment="CENTER"
                                  spacing="8"
                                  style="-fx-background-color:#F0F9FF;
                                         -fx-background-radius:10;
                                         -fx-padding:15;
                                         -fx-border-color:#BFDBFE;
                                         -fx-border-radius:10;"
                                  GridPane.columnIndex="0">

                                <Label text="🔵"
                                       style="-fx-font-size:26;
                                              -fx-text-alignment:center;"/>

                                <Label text="Check In"
                                       style="-fx-font-weight:bold;
                                              -fx-text-alignment:center;"/>

                                <TextField fx:id="txtCheckIn"
                                           promptText="HH:mm"
                                           alignment="CENTER"
                                           style="-fx-font-size:14;"/>

                                <CheckBox fx:id="chkCheckIn"
                                          text="✓ Selesai"
                                          style="-fx-font-size:12;"/>

                            </VBox>

                            <!-- SNACK PAGI -->

                            <VBox alignment="CENTER"
                                  spacing="8"
                                  style="-fx-background-color:#FFFBEB;
                                         -fx-background-radius:10;
                                         -fx-padding:15;
                                         -fx-border-color:#FCD34D;
                                         -fx-border-radius:10;"
                                  GridPane.columnIndex="1">

                                <Label text="🟠"
                                       style="-fx-font-size:26;
                                              -fx-text-alignment:center;"/>

                                <Label text="Snack Pagi"
                                       style="-fx-font-weight:bold;
                                              -fx-text-alignment:center;"/>

                                <TextField fx:id="txtSnackPagi"
                                           promptText="HH:mm"
                                           alignment="CENTER"
                                           style="-fx-font-size:14;"/>

                                <CheckBox fx:id="chkSnackPagi"
                                          text="✓ Selesai"
                                          style="-fx-font-size:12;"/>

                            </VBox>

                            <!-- MAKAN SIANG -->

                            <VBox alignment="CENTER"
                                  spacing="8"
                                  style="-fx-background-color:#F0FDF4;
                                         -fx-background-radius:10;
                                         -fx-padding:15;
                                         -fx-border-color:#BBEF63;
                                         -fx-border-radius:10;"
                                  GridPane.columnIndex="2">

                                <Label text="🍽"
                                       style="-fx-font-size:26;
                                              -fx-text-alignment:center;"/>

                                <Label text="Makan Siang"
                                       style="-fx-font-weight:bold;
                                              -fx-text-alignment:center;"/>

                                <TextField fx:id="txtMakanSiang"
                                           promptText="HH:mm"
                                           alignment="CENTER"
                                           style="-fx-font-size:14;"/>

                                <CheckBox fx:id="chkMakanSiang"
                                          text="✓ Selesai"
                                          style="-fx-font-size:12;"/>

                            </VBox>

                            <!-- SNACK SORE -->

                            <VBox alignment="CENTER"
                                  spacing="8"
                                  style="-fx-background-color:#FEF3C7;
                                         -fx-background-radius:10;
                                         -fx-padding:15;
                                         -fx-border-color:#FCD34D;
                                         -fx-border-radius:10;"
                                  GridPane.columnIndex="3">

                                <Label text="🍪"
                                       style="-fx-font-size:26;
                                              -fx-text-alignment:center;"/>

                                <Label text="Snack Sore"
                                       style="-fx-font-weight:bold;
                                              -fx-text-alignment:center;"/>

                                <TextField fx:id="txtSnackSore"
                                           promptText="HH:mm"
                                           alignment="CENTER"
                                           style="-fx-font-size:14;"/>

                                <CheckBox fx:id="chkSnackSore"
                                          text="✓ Selesai"
                                          style="-fx-font-size:12;"/>

                            </VBox>

                            <!-- MANDI -->

                            <VBox alignment="CENTER"
                                  spacing="8"
                                  style="-fx-background-color:#F0F9FF;
                                         -fx-background-radius:10;
                                         -fx-padding:15;
                                         -fx-border-color:#93C5FD;
                                         -fx-border-radius:10;"
                                  GridPane.columnIndex="4">

                                <Label text="🛁"
                                       style="-fx-font-size:26;
                                              -fx-text-alignment:center;"/>

                                <Label text="Mandi"
                                       style="-fx-font-weight:bold;
                                              -fx-text-alignment:center;"/>

                                <TextField fx:id="txtMandi"
                                           promptText="HH:mm"
                                           alignment="CENTER"
                                           style="-fx-font-size:14;"/>

                                <CheckBox fx:id="chkMandi"
                                          text="✓ Selesai"
                                          style="-fx-font-size:12;"/>

                            </VBox>

                            <!-- TIDUR -->

                            <VBox alignment="CENTER"
                                  spacing="8"
                                  style="-fx-background-color:#F3F4F6;
                                         -fx-background-radius:10;
                                         -fx-padding:15;
                                         -fx-border-color:#D1D5DB;
                                         -fx-border-radius:10;"
                                  GridPane.columnIndex="5">

                                <Label text="😴"
                                       style="-fx-font-size:26;
                                              -fx-text-alignment:center;"/>

                                <Label text="Tidur"
                                       style="-fx-font-weight:bold;
                                              -fx-text-alignment:center;"/>

                                <TextField fx:id="txtTidur"
                                           promptText="HH:mm"
                                           alignment="CENTER"
                                           style="-fx-font-size:14;"/>

                                <CheckBox fx:id="chkTidur"
                                          text="✓ Selesai"
                                          style="-fx-font-size:12;"/>

                            </VBox>

                            <!-- CHECK OUT -->

                            <VBox alignment="CENTER"
                                  spacing="8"
                                  style="-fx-background-color:#FEE2E2;
                                         -fx-background-radius:10;
                                         -fx-padding:15;
                                         -fx-border-color:#FECACA;
                                         -fx-border-radius:10;"
                                  GridPane.columnIndex="6">

                                <Label text="🔴"
                                       style="-fx-font-size:26;
                                              -fx-text-alignment:center;"/>

                                <Label text="Check Out"
                                       style="-fx-font-weight:bold;
                                              -fx-text-alignment:center;"/>

                                <TextField fx:id="txtCheckOut"
                                           promptText="HH:mm"
                                           alignment="CENTER"
                                           style="-fx-font-size:14;"/>

                                <CheckBox fx:id="chkCheckOut"
                                          text="✓ Selesai"
                                          style="-fx-font-size:12;"/>

                            </VBox>

                        </GridPane>

                    </ScrollPane>

                </VBox>

                <!-- ================= CATATAN CAREGIVER ================= -->

                <VBox spacing="15"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;
                             -fx-padding:20;">

                    <Label text="📝 CATATAN CAREGIVER"
                           style="-fx-font-size:20;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1F2937;"/>

                    <TextArea fx:id="txtCatatan"
                              prefHeight="120"
                              wrapText="true"
                              promptText="Tuliskan catatan kegiatan, kondisi anak, makanan yang dihabiskan, mood, atau hal penting lainnya..."
                              style="-fx-font-size:13;
                                     -fx-control-inner-background:#F9FAFB;"/>

                </VBox>

                <!-- ================= AKTIVITAS HARIAN ================= -->

                <VBox spacing="15"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;
                             -fx-padding:20;">

                    <Label text="🎯 AKTIVITAS HARIAN"
                           style="-fx-font-size:20;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1F2937;"/>

                    <TextArea fx:id="txtAktivitasHarian"
                              prefHeight="100"
                              wrapText="true"
                              promptText="Contoh : Bermain Puzzle, Menggambar, Bernyanyi, Belajar Huruf, Bermain Outdoor..."
                              style="-fx-font-size:13;
                                     -fx-control-inner-background:#F9FAFB;"/>

                </VBox>

                <!-- ================= BUTTONS ================= -->

                <HBox spacing="15"
                      alignment="CENTER_RIGHT">

                    <Button fx:id="btnReset"
                            text="🔄 Reset"
                            prefWidth="120"
                            prefHeight="42"
                            style="-fx-background-color:white;
                                   -fx-border-color:#D1D5DB;
                                   -fx-border-radius:8;
                                   -fx-background-radius:8;
                                   -fx-font-size:15;
                                   -fx-font-weight:bold;
                                   -fx-text-fill:#6B7280;"/>

                    <Button fx:id="btnSimpan"
                            text="💾 Simpan Kegiatan"
                            prefWidth="200"
                            prefHeight="42"
                            style="-fx-background-color:#16A34A;
                                   -fx-text-fill:white;
                                   -fx-background-radius:8;
                                   -fx-font-size:15;
                                   -fx-font-weight:bold;
                                   -fx-cursor:hand;"/>

                </HBox>

            </VBox>

        </HBox>

    </center>

</BorderPane>