<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.kidsdaycareactivitycenter.DashboardAdmin.DashboardAdminController"
            prefWidth="1100"
            prefHeight="700"
            style="-fx-background-color:#F5F7FB;">

    <children>

        <!-- ================= BACKGROUND ================= -->

        <Pane layoutX="15"
              layoutY="15"
              prefWidth="1070"
              prefHeight="670"
              style="-fx-background-color:white;
                     -fx-background-radius:15;
                     -fx-border-color:#D6E4F0;
                     -fx-border-radius:15;
                     -fx-border-width:1;" />

        <!-- ================= HEADER ================= -->

        <HBox layoutX="20"
              layoutY="20"
              prefWidth="1060"
              prefHeight="90"
              alignment="CENTER_LEFT"
              spacing="20"
              style="-fx-background-color:linear-gradient(to right,#2563EB,#3B82F6);
                     -fx-background-radius:15;">

            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <children>

                <!-- Logo -->

                <Label text="🧸"
                       style="-fx-font-size:40;" />

                <!-- Judul -->

                <VBox spacing="3">

                    <children>

                        <Label text="KIDS DAYCARE ACTIVITY CENTER"
                               style="-fx-font-size:24;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:white;" />

                        <Label text="Dashboard Administrator"
                               style="-fx-font-size:14;
                                      -fx-text-fill:white;" />

                    </children>

                </VBox>

                <!-- Spacer -->

                <Pane HBox.hgrow="ALWAYSs"/>

                <!-- Informasi Login -->

                <VBox alignment="CENTER_RIGHT"
                      spacing="4">

                    <children>

                        <Label text="Login"
                               style="-fx-text-fill:white;
                                      -fx-font-size:12;" />

                        <Label fx:id="lblLogin"
                               text="Administrator"
                               style="-fx-text-fill:white;
                                      -fx-font-size:16;
                                      -fx-font-weight:bold;" />

                        <Label fx:id="lblRole"
                               text="Admin"
                               style="-fx-text-fill:white;
                                      -fx-font-size:13;" />

                    </children>

                </VBox>

                <!-- Garis -->

                <Separator orientation="VERTICAL"
                           prefHeight="55"/>

                <!-- Tanggal & Jam -->

                <VBox alignment="CENTER_RIGHT"
                      spacing="4">

                    <children>

                        <Label text="Tanggal"
                               style="-fx-text-fill:white;
                                      -fx-font-size:12;" />

                        <Label fx:id="lblTanggal"
                               text="-"
                               style="-fx-text-fill:white;
                                      -fx-font-size:14;
                                      -fx-font-weight:bold;" />

                        <Label fx:id="lblJam"
                               text="00:00:00"
                               style="-fx-text-fill:white;
                                      -fx-font-size:14;
                                      -fx-font-weight:bold;" />

                    </children>

                </VBox>

                <!-- Logout -->

                <Button fx:id="btnLogout"
                        text="Logout"
                        onAction="#logout"
                        prefWidth="95"
                        prefHeight="38"
                        style="-fx-background-color:#EF4444;
                               -fx-background-radius:8;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;" />

            </children>

        </HBox>

        <!-- ================= CARD STATISTIK ================= -->

        <GridPane layoutX="35"
                  layoutY="125"
                  hgap="20"
                  vgap="20"
                  prefWidth="1030">

            <children>

                <!-- ================= CARD TOTAL ANAK ================= -->

                <VBox GridPane.columnIndex="0"
                      alignment="CENTER"
                      spacing="8"
                      prefWidth="235"
                      prefHeight="120"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;
                             -fx-border-radius:12;">

                    <children>

                        <Label text="👶"
                               style="-fx-font-size:30;" />

                        <Label text="Total Anak"
                               style="-fx-font-size:15;
                                      -fx-font-weight:bold;" />

                        <Label fx:id="lblTotalAnak"
                               text="0"
                               style="-fx-font-size:32;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#2563EB;" />

                    </children>

                </VBox>

                <!-- ================= CARD TOTAL ORANG TUA ================= -->

                <VBox GridPane.columnIndex="1"
                      alignment="CENTER"
                      spacing="8"
                      prefWidth="235"
                      prefHeight="120"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;
                             -fx-border-radius:12;">

                    <children>

                        <Label text="👨‍👩‍👧"
                               style="-fx-font-size:30;" />

                        <Label text="Total Orang Tua"
                               style="-fx-font-size:15;
                                      -fx-font-weight:bold;" />

                        <Label fx:id="lblTotalOrangTua"
                               text="0"
                               style="-fx-font-size:32;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#16A34A;" />

                    </children>

                </VBox>

                <!-- ================= CARD TOTAL KARYAWAN ================= -->

                <VBox GridPane.columnIndex="2"
                      alignment="CENTER"
                      spacing="8"
                      prefWidth="235"
                      prefHeight="120"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;
                             -fx-border-radius:12;">

                    <children>

                        <Label text="👨‍💼"
                               style="-fx-font-size:30;" />

                        <Label text="Total Karyawan"
                               style="-fx-font-size:15;
                                      -fx-font-weight:bold;" />

                        <Label fx:id="lblTotalKaryawan"
                               text="0"
                               style="-fx-font-size:32;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#F59E0B;" />

                    </children>

                </VBox>

                <!-- ================= CARD ANAK HARI INI ================= -->

                <VBox GridPane.columnIndex="3"
                      alignment="CENTER"
                      spacing="8"
                      prefWidth="235"
                      prefHeight="120"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#E5E7EB;
                             -fx-border-radius:12;">

                    <children>

                        <Label text="📅"
                               style="-fx-font-size:30;" />

                        <Label text="Anak Hari Ini"
                               style="-fx-font-size:15;
                                      -fx-font-weight:bold;" />

                        <Label fx:id="lblAnakHariIni"
                               text="0"
                               style="-fx-font-size:32;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#EF4444;" />

                    </children>

                </VBox>

            </children>

        </GridPane>

        <!-- ================= MENU MASTER ================= -->

        <Pane layoutX="35"
              layoutY="285"
              prefWidth="320"
              prefHeight="355"
              style="-fx-background-color:white;
                     -fx-background-radius:12;
                     -fx-border-color:#E5E7EB;
                     -fx-border-radius:12;">

            <children>

                <Label layoutX="20"
                       layoutY="20"
                       text="MASTER DATA"
                       style="-fx-font-size:20;
                              -fx-font-weight:bold;
                              -fx-text-fill:#2563EB;"/>

                <Separator layoutX="20"
                           layoutY="55"
                           prefWidth="280"/>

                <!-- MASTER KARYAWAN -->

                <Button layoutX="25"
                        layoutY="75"
                        prefWidth="270"
                        prefHeight="40"
                        text="👨‍💼  Master Karyawan"
                        onAction="#masterKaryawan"
                        style="-fx-background-color:#2563EB;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

                <!-- MASTER ORANG TUA -->

                <Button layoutX="25"
                        layoutY="130"
                        prefWidth="270"
                        prefHeight="40"
                        text="👨‍👩‍👧  Master Orang Tua"
                        onAction="#masterOrangTua"
                        style="-fx-background-color:#16A34A;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

                <!-- MASTER ANAK -->

                <Button layoutX="25"
                        layoutY="185"
                        prefWidth="270"
                        prefHeight="40"
                        text="👶  Master Anak"
                        onAction="#masterAnak"
                        style="-fx-background-color:#F59E0B;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

                <!-- MASTER PAKET DAYCARE -->

                <Button layoutX="25"
                        layoutY="240"
                        prefWidth="270"
                        prefHeight="40"
                        text="📦  Master Paket Daycare"
                        onAction="#paketDaycare"
                        style="-fx-background-color:#8B5CF6;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

                <!-- ACTIVITY SCHEDULE -->

                <Button layoutX="25"
                        layoutY="295"
                        prefWidth="270"
                        prefHeight="40"
                        text="📅  Activity Schedule"
                        onAction="#activitySchedule"
                        style="-fx-background-color:#0EA5E9;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

            </children>

        </Pane>

        <!-- ================= MENU TRANSAKSI ================= -->

        <Pane layoutX="390"
              layoutY="285"
              prefWidth="320"
              prefHeight="355"
              style="-fx-background-color:white;
                     -fx-background-radius:12;
                     -fx-border-color:#E5E7EB;
                     -fx-border-radius:12;">

            <children>

                <Label layoutX="20"
                       layoutY="20"
                       text="TRANSAKSI"
                       style="-fx-font-size:20;
                              -fx-font-weight:bold;
                              -fx-text-fill:#2563EB;"/>

                <Separator layoutX="20"
                           layoutY="55"
                           prefWidth="280"/>

                <Button layoutX="25"
                        layoutY="75"
                        prefWidth="270"
                        prefHeight="40"
                        text="🏫  Transaksi Daycare"
                        onAction="#transaksiDaycare"
                        style="-fx-background-color:#2563EB;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

                <Button layoutX="25"
                        layoutY="130"
                        prefWidth="270"
                        prefHeight="40"
                        text="💳  Transaksi Payment"
                        onAction="#transaksiPayment"
                        style="-fx-background-color:#16A34A;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

            </children>

        </Pane>

        <!-- ================= MENU LAPORAN ================= -->

        <Pane layoutX="745"
              layoutY="285"
              prefWidth="320"
              prefHeight="355"
              style="-fx-background-color:white;
                     -fx-background-radius:12;
                     -fx-border-color:#E5E7EB;
                     -fx-border-radius:12;">

            <children>

                <Label layoutX="20"
                       layoutY="20"
                       text="LAPORAN"
                       style="-fx-font-size:20;
                              -fx-font-weight:bold;
                              -fx-text-fill:#2563EB;"/>

                <Separator layoutX="20"
                           layoutY="55"
                           prefWidth="280"/>

                <Button layoutX="25"
                        layoutY="75"
                        prefWidth="270"
                        prefHeight="40"
                        text="📄  Laporan Daycare"
                        onAction="#laporanDaycare"
                        style="-fx-background-color:#2563EB;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

                <Button layoutX="25"
                        layoutY="130"
                        prefWidth="270"
                        prefHeight="40"
                        text="💰  Laporan Payment"
                        onAction="#laporanPayment"
                        style="-fx-background-color:#F59E0B;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

                <Button layoutX="25"
                        layoutY="185"
                        prefWidth="270"
                        prefHeight="40"
                        text="📊  Laporan Activity"
                        onAction="#laporanActivity"
                        style="-fx-background-color:#8B5CF6;
                               -fx-text-fill:white;
                               -fx-font-size:14;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;"/>

            </children>

        </Pane>

        <!-- ================= FOOTER ================= -->

        <Separator layoutX="25"
                   layoutY="655"
                   prefWidth="1045"/>

        <Label fx:id="lblFooterLogin"
               layoutX="35"
               layoutY="665"
               text="Administrator (Admin)"
               style="-fx-font-size:13;
                      -fx-font-weight:bold;
                      -fx-text-fill:#6B7280;"/>

    </children>

</AnchorPane>