<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.kidsdaycareactivitycenter.DashboardAdmin.DashboardAdminController"
            prefWidth="1250"
            prefHeight="720"
            style="-fx-background-color:#F5F7FB;">

    <children>

        <VBox layoutX="15" layoutY="15" prefWidth="1220" prefHeight="690" spacing="18"
              style="-fx-background-color:white;-fx-background-radius:18;-fx-border-color:#E5E7EB;-fx-border-radius:18;">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <children>

                <HBox alignment="CENTER_LEFT" spacing="15">

                    <Label text="🧸" style="-fx-font-size:34;"/>

                    <VBox HBox.hgrow="ALWAYS">
                        <children>
                            <Label text="KIDDIELAND"
                                   style="-fx-font-size:24;-fx-font-weight:bold;"/>
                            <Label text="DAYCARE MANAGEMENT SYSTEM"
                                   style="-fx-font-size:11;-fx-text-fill:#6B7280;"/>
                        </children>
                    </VBox>

                    <HBox spacing="20" alignment="CENTER">
                        <VBox alignment="CENTER">
                            <Label fx:id="lblTotalAnak" text="0" style="-fx-font-size:20;-fx-font-weight:bold;"/>
                            <Label text="ANAK"/>
                        </VBox>

                        <VBox alignment="CENTER">
                            <Label fx:id="lblTotalOrangTua" text="0" style="-fx-font-size:20;-fx-font-weight:bold;"/>
                            <Label text="ORTU"/>
                        </VBox>

                        <VBox alignment="CENTER">
                            <Label fx:id="lblTotalKaryawan" text="0" style="-fx-font-size:20;-fx-font-weight:bold;"/>
                            <Label text="STAFF"/>
                        </VBox>

                        <VBox alignment="CENTER">
                            <Label fx:id="lblAnakHariIni" text="0" style="-fx-font-size:20;-fx-font-weight:bold;"/>
                            <Label text="HADIR"/>
                        </VBox>

                        <Separator orientation="VERTICAL"/>

                        <VBox>
                            <Label text="ADMIN" style="-fx-text-fill:#F97316;"/>
                            <Label fx:id="lblLogin" text="Administrator" style="-fx-font-weight:bold;"/>
                            <Label fx:id="lblRole" text="Admin"/>
                            <HBox spacing="5">
                                <Label fx:id="lblTanggal" text="-"/>
                                <Label text="|"/>
                                <Label fx:id="lblJam" text="-"/>
                            </HBox>
                        </VBox>

                        <Button fx:id="btnLogout"
                                text="Keluar"
                                onAction="#logout"
                                prefWidth="90"
                                style="-fx-background-color:#EF4444;-fx-text-fill:white;-fx-background-radius:8;"/>
                    </HBox>

                </HBox>

                <Separator/>

                <HBox spacing="15" VBox.vgrow="ALWAYS">

                    <VBox prefWidth="290" spacing="10"
                          style="-fx-background-color:white;-fx-border-color:#E5E7EB;-fx-background-radius:12;-fx-border-radius:12;">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                        <children>
                            <Label text="01 KELOLA MASTER"
                                   style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#2563EB;"/>
                            <Button text="👨‍💼 Master Karyawan" onAction="#masterKaryawan" prefHeight="42"
                                    style="-fx-background-color:#EEF4FF;-fx-background-radius:10;-fx-alignment:CENTER_LEFT;"/>
                            <Button text="👨‍👩‍👧 Master Orang Tua" onAction="#masterOrangTua" prefHeight="42"
                                    style="-fx-background-color:#EEF4FF;-fx-background-radius:10;-fx-alignment:CENTER_LEFT;"/>
                            <Button text="👶 Master Anak" onAction="#masterAnak" prefHeight="42"
                                    style="-fx-background-color:#EEF4FF;-fx-background-radius:10;-fx-alignment:CENTER_LEFT;"/>
                            <Button text="📦 Paket Daycare" onAction="#paketDaycare" prefHeight="42"
                                    style="-fx-background-color:#EEF4FF;-fx-background-radius:10;-fx-alignment:CENTER_LEFT;"/>
                            <Button text="📅 Activity Schedule" onAction="#activitySchedule" prefHeight="42"
                                    style="-fx-background-color:#EEF4FF;-fx-background-radius:10;-fx-alignment:CENTER_LEFT;"/>
                        </children>
                    </VBox>

                    <VBox prefWidth="290" spacing="10"
                          style="-fx-background-color:white;-fx-border-color:#E5E7EB;">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                        <children>
                            <Label text="02 TRANSAKSI DAYCARE"
                                   style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#16A34A;"/>
                            <Button text="🏫 Transaksi Daycare" onAction="#transaksiDaycare" prefHeight="42"
                                    style="-fx-background-color:#ECFDF5;-fx-background-radius:10;-fx-alignment:CENTER_LEFT;"/>
                        </children>
                    </VBox>

                    <VBox prefWidth="290" spacing="10"
                          style="-fx-background-color:white;-fx-border-color:#E5E7EB;">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                        <children>
                            <Label text="03 KELOLA PAYMENT"
                                   style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#F59E0B;"/>
                            <Button text="💳 Transaksi Payment" onAction="#transaksiPayment" prefHeight="42"
                                    style="-fx-background-color:#FFF7E8;-fx-background-radius:10;-fx-alignment:CENTER_LEFT;"/>
                        </children>
                    </VBox>

                </HBox>

                <Separator/>

                <Label fx:id="lblFooterLogin"
                       text="Administrator (Admin)"
                       style="-fx-text-fill:#6B7280;"/>

            </children>

        </VBox>

    </children>

</AnchorPane>
